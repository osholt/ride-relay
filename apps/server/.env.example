RIDE_RELAY_ENVIRONMENT=production
RIDE_RELAY_DATABASE_URL=postgresql+psycopg://ride_relay:replace-me@db:5432/ride_relay
RIDE_RELAY_DATA_ENCRYPTION_KEY=replace-with-base64url-32-byte-key
RIDE_RELAY_CURSOR_SIGNING_KEY=replace-with-another-base64url-32-byte-key
RIDE_RELAY_TRUSTED_HOSTS=["relay.example.com","127.0.0.1","localhost"]
RIDE_RELAY_FORWARDED_ALLOW_IPS=127.0.0.1
RIDE_RELAY_RIDE_RETENTION_HOURS=72
RIDE_RELAY_ENDED_RIDE_GRACE_HOURS=24
RIDE_RELAY_MAXIMUM_ACTIVE_RIDES=100
RIDE_RELAY_MAXIMUM_EVENTS_PER_RIDE=5000
RIDE_RELAY_MAXIMUM_STORED_BYTES_PER_RIDE=26214400
RIDE_RELAY_MAXIMUM_REPLAYS_PER_RIDE=5000
